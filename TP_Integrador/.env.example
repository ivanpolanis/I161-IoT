# Copiar a .env y completar con valores reales
# NUNCA commitear el .env con credenciales reales

# MQTT - usuario para el ESP32
MOSQ_ESP32_USER=esp32
MOSQ_ESP32_PASS=changeme_esp32

# MQTT - usuario para Node-RED
MOSQ_NODERED_USER=nodered
MOSQ_NODERED_PASS=changeme_nodered

# MQTT - usuario admin (para mosquitto_pub/sub de diagnóstico)
MOSQ_ADMIN_USER=admin
MOSQ_ADMIN_PASS=changeme_admin

# Telegram Bot
# Obtener token: hablar con @BotFather en Telegram, /newbot
TELEGRAM_TOKEN=123456789:ABCDEFabcdef1234567890

# IDs de chat de administradores (separados por coma)
# Obtener ID: hablar con @userinfobot en Telegram
TELEGRAM_ADMIN_IDS=123456789,987654321

# Node-RED credential encryption key (must match what was used when flows were saved)
NODE_RED_CREDENTIAL_SECRET=tpi-iot-secret

# Grafana
GRAFANA_USER=admin
GRAFANA_PASS=admin
