{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "datasource", "id": "influxdb", "name": "InfluxDB", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "bargauge", "name": "Bar gauge", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "Sistema de Control de Acceso RFID - TP Integrador",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10},
          "unit": "short"
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "granted"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "denied"},  "properties": [{"id": "color", "value": {"fixedColor": "red",   "mode": "fixed"}}]}
        ]
      },
      "gridPos": {"h": 8, "w": 16, "x": 0, "y": 0},
      "id": 1,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
          "query": "SELECT count(\"count\") FROM \"access_events\" WHERE $timeFilter GROUP BY time($__interval), \"outcome\" fill(0)",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "title": "Accesos por tiempo (granted vs denied)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}, "unit": "short"}
      },
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none"},
      "targets": [
        {
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
          "query": "SELECT count(\"count\") FROM \"access_events\" WHERE \"outcome\" = 'denied' AND $timeFilter",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "title": "Denegados (período)",
      "type": "stat"
    },
    {
      "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}, "unit": "short"}
      },
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 4},
      "id": 3,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [
        {
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
          "query": "SELECT count(\"count\") FROM \"access_events\" WHERE \"outcome\" = 'granted' AND $timeFilter",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "title": "Accesos concedidos (período)",
      "type": "stat"
    },
    {
      "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]},
          "unit": "short"
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 4,
      "options": {"reduceOptions": {"calcs": ["sum"]}, "orientation": "horizontal", "displayMode": "gradient"},
      "targets": [
        {
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
          "query": "SELECT count(\"count\") FROM \"access_events\" WHERE $timeFilter GROUP BY \"uid\"",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "title": "Top UIDs por cantidad de accesos",
      "type": "bargauge"
    },
    {
      "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "source"}, "properties": [{"id": "custom.width", "value": 90}]},
          {"matcher": {"id": "byName", "options": "outcome"}, "properties": [{"id": "custom.width", "value": 80}]}
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 5,
      "options": {"showHeader": true},
      "targets": [
        {
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
          "query": "SELECT \"uid\", \"outcome\", \"source\" FROM \"access_events\" WHERE $timeFilter ORDER BY time DESC LIMIT 50",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "title": "Eventos recientes",
      "type": "table"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 37,
  "style": "dark",
  "tags": ["acceso", "rfid", "iot"],
  "templating": {"list": []},
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Control de Acceso RFID",
  "uid": "acceso-rfid-iot",
  "version": 1
}
