{
  "title": "Monitoreo temperatura y humedad",
  "uid": "ambiente-iot",
  "description": "Temperatura y humedad desde ESP32 vía MQTT",
  "tags": ["iot", "ambiente"],
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Temperatura (°C)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "celsius",
          "min": 0,
          "max": 50
        }
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": "InfluxDB",
          "query": "SELECT \"temp\" FROM \"ambiente\" WHERE $timeFilter",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Humedad (%)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": "InfluxDB",
          "query": "SELECT \"hum\" FROM \"ambiente\" WHERE $timeFilter",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Temperatura actual",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 15 },
              { "color": "orange", "value": 30 },
              { "color": "red", "value": 38 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": "InfluxDB",
          "query": "SELECT last(\"temp\") FROM \"ambiente\"",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Humedad actual",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 30 },
              { "color": "blue", "value": 70 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "datasource": "InfluxDB",
          "query": "SELECT last(\"hum\") FROM \"ambiente\"",
          "rawQuery": true,
          "refId": "A"
        }
      ]
    }
  ]
}
